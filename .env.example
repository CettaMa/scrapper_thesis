# Input and output
CCTV_CONFIG_FILE=cctv_points.csv
CCTV_OUTPUT_ROOT=dataset

TOMTOM_API=isi_dengan_api_key_anda

# Video segmentation
VIDEO_CONTAINER=ts
SEGMENT_SECONDS=28

# HLS stability - recommended for unstable public HLS CCTV
HLS_RECONNECT_AT_EOF=false
HLS_LIVE_START_INDEX=-1
SEGMENT_ATCLOCKTIME=false
PREFLIGHT_CHECK=true
FFMPEG_RECONNECT_ON_HTTP_ERROR=5xx
OFFLINE_RETRY_SECONDS=300
NETWORK_RETRY_SECONDS=60
RESTART_DELAY_SECONDS=5
HEALTH_CHECK_SECONDS=30
STALE_FILE_SECONDS=240
FFMPEG_RW_TIMEOUT=10000000
FFMPEG_RECONNECT_DELAY_MAX=10

# Recommended recording mode
# copy = paling ringan dan stabil untuk rekaman mentah.
# smooth/transcode = pakai encoding ulang untuk mengecilkan ukuran dan CFR.
FFMPEG_TRANSPORT_MODE=copy

# Transcode options, only used when FFMPEG_TRANSPORT_MODE=smooth or transcode
VIDEO_ENCODER=libx264
OUTPUT_FPS=10
OUTPUT_HEIGHT=0
TRANSCODE_PRESET=p4
TARGET_BITRATE=650k
MAX_BITRATE=900k
BUFFER_SIZE=1300k
TRANSCODE_CRF=28
SEGMENT_KEYFRAME_SECONDS=2

# Archive encoder
# Set false jika ingin menyimpan raw .ts saja tanpa digabung/encode ke MP4.
# RTX 3060 Laptop supports H.264/H.265 NVENC encode, but not AV1 NVENC encode.
ARCHIVE_ENCODER_ENABLED=false
ARCHIVE_INTERVAL_SECONDS=300
ARCHIVE_SCAN_SECONDS=60
ARCHIVE_SAFE_AGE_SECONDS=90
ARCHIVE_DELETE_RAW_AFTER_SUCCESS=true
ARCHIVE_VIDEO_ENCODER=libx264
ARCHIVE_PRESET=p4
ARCHIVE_TARGET_BITRATE=650k
ARCHIVE_MAX_BITRATE=900k
ARCHIVE_BUFFER_SIZE=1300k
ARCHIVE_OUTPUT_HEIGHT=0

# Google Drive upload for raw .ts files
# Share the target Drive folder with the service account email first.
GOOGLE_DRIVE_UPLOAD_ENABLED=true
GOOGLE_DRIVE_SERVICE_ACCOUNT_FILE=secrets/super_secret.json
GOOGLE_DRIVE_FOLDER_ID=1E9D3tmt2-MHWzqAmX4Wcr1a_NLOv9Ohw
GOOGLE_DRIVE_SCAN_SECONDS=60
GOOGLE_DRIVE_SAFE_AGE_SECONDS=90
GOOGLE_DRIVE_DELETE_LOCAL_AFTER_UPLOAD=false

# FFmpeg diagnostics
FFMPEG_LOGLEVEL=warning
FFMPEG_ANALYZEDURATION=10000000
FFMPEG_PROBESIZE=10000000
FFMPEG_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64)
FFMPEG_REFERER=https://atcs-dishubkbb.urbanaccess.net/
FFMPEG_ORIGIN=https://atcs.bandungbaratkab.go.id

# Metadata
METADATA_INTERVAL_SECONDS=300
TOMTOM_INTERVAL_SECONDS=300
OPENMETEO_INTERVAL_SECONDS=300

# Storage lifecycle
DISK_CHECK_SECONDS=300
RETENTION_DAYS=7
MIN_FREE_SPACE_GB=20

# Fallback coordinate jika CSV lat/lon kosong
DEFAULT_LAT=-6.851117
DEFAULT_LON=107.496586

# Optional secret; isi di file .env lokal Anda, jangan commit ke repository
# TOMTOM_API=isi_dengan_api_key_anda
